# Runtime environment for the DyF training campaign.
# Copy to .env, fill in values, then:
#     source .env
# before any of the launch scripts. AWS credentials come from your
# normal aws CLI config (~/.aws/credentials) — they are NOT in this file.

# ── Weights & Biases ──────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=dyf
WANDB_ENTITY=

# ── S3 ────────────────────────────────────────────────────────────
# Checkpoint bucket — workers read+write. Create with:
#     aws s3 mb s3://dyf-checkpoints --region us-west-2
CKPT_BUCKET=s3://dyf-checkpoints

# Dataset bucket (optional — only used if you mirror ImageNet to S3
# instead of using a dstack volume / EBS snapshot).
DATA_BUCKET=

# EBS snapshot containing the dataset volume, used by bare-EC2 launch
# (scripts/infra/run_worker.sh). Create the snapshot once from a
# data-prep instance. Leave blank if you only use dstack volumes.
DATA_SNAPSHOT=

# ── Campaign controls ─────────────────────────────────────────────
# Ordered list of AZs the watchdog rotates through. First AZ is tried
# first; if every AZ rejects, watchdog sleeps CAPACITY_SLEEP_SEC and
# starts over. us-west-2d is typically cheapest for p5/H100.
CAMPAIGN_AZS="us-west-2d us-west-2c us-west-2b us-west-2a"

# How many workers to keep alive.
TARGET_WORKERS=2

# Spot instance type. p5.48xlarge = 8×H100. For dryrun use g5.xlarge.
INSTANCE_TYPE=p5.48xlarge

# Tag prefix on EC2 instances; lets multiple campaigns coexist (the
# watchdog's count_live_workers filter uses this).
CAMPAIGN=dyf

# ── AWS region hint ───────────────────────────────────────────────
AWS_DEFAULT_REGION=us-west-2
